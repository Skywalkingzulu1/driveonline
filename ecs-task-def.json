{
  "family": "driveonline-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::YOUR_ACCOUNT_ID:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "driveonline",
      "image": "ghcr.io/skywalkingzulu1/driveonline:latest",
      "portMappings": [
        {
          "containerPort": 5000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "SECRET_KEY", "value": "super-secret-key" },
        { "name": "JWT_SECRET_KEY", "value": "jwt-super-secret" },
        { "name": "MAIL_SERVER", "value": "mailhog" },
        { "name": "MAIL_PORT", "value": "1025" }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/driveonline",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}